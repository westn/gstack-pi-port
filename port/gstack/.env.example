# Copy to .env and fill in values
# bun auto-loads .env — no dotenv needed

# Optional: pin eval runner to a specific pi provider/model.
# If unset, pi uses your default configured provider/model.
PI_EVAL_PROVIDER=
PI_EVAL_MODEL=
PI_EVAL_THINKING=

# Configure at least one provider API key supported by pi.
# Examples (pick what you use):
# OPENAI_API_KEY=...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=...
