# Copy to .env and fill in values if needed
# bun auto-loads .env — no dotenv needed

# Optional eval overrides for pi-based judge/E2E runs.
# If omitted, pi uses your default provider/model config.
# PI_EVAL_PROVIDER=openai
# PI_EVAL_MODEL=gpt-5.1
# PI_EVAL_THINKING=low
# PI_EVAL_TIMEOUT_MS=60000

# If you use key-based auth instead of a logged-in subscription,
# set the provider key expected by your chosen pi provider.
# OPENAI_API_KEY=...
# ANTHROPIC_API_KEY=...
# GEMINI_API_KEY=...
